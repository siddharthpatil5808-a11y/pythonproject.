library = []

def add_book():
    book = input("Enter book name: ")
    library.append(book)
    print("Book added successfully")

def view_books():
    print("Books in Library:")
    for book in library:
        print(book)

def delete_book():
    book = input("Enter book name to delete: ")
    if book in library:
        library.remove(book)
        print("Book removed")
    else:
        print("Book not found")

while True:
    print("\n1.Add Book")
    print("2.View Books")
    print("3.Delete Book")
    print("4.Exit")

    choice = input("Enter choice: ")

    if choice == "1":
        add_book()
    elif choice == "2":
        view_books()
    elif choice == "3":
        delete_book()
    elif choice == "4":
        break
    else:
        print("Invalid choice")
